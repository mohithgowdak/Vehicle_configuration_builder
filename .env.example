# Paths to your input data files. Copy to .env and fill in real absolute paths.

# Part Number Dataset (Excel). Columns: Partnumber, Nomenclature, ECU Qualifier, Type.
PART_NUMBER_XLSX=D:/artiMIND/Vehicle_configuration_builder/data/part_numbers.xlsx

# CDD-equivalent codebook (Excel). One row per qualifier with datatype + encoding rule.
# If you have the real CANdela XML instead, point CDD_XML here and leave CDD_XLSX blank.
CDD_XLSX=D:/artiMIND/Vehicle_configuration_builder/data/cdd.xlsx
CDD_XML=

# Reference .par used as the header template (S/H lines) and ground-truth for validation.
REFERENCE_PAR=D:/artiMIND/Vehicle_configuration_builder/data/reference.par

# Where generated .par files are written.
OUTPUT_DIR=D:/artiMIND/Vehicle_configuration_builder/out

# Ollama (local LLM). Leave OLLAMA_HOST blank to use the default http://localhost:11434.
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=

# Optional: animated background. Drop a .gif/.png/.jpg here and the app will
# render it behind the chat with a dark overlay. Leave blank to use the default gradient.
BACKGROUND_IMAGE=D:/artiMIND/Vehicle_configuration_builder/assets/truck.gif
# 0.00 = no overlay (background fully visible), 0.85 = very dark. Default 0.55.
BACKGROUND_OVERLAY=0.55
